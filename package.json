{
  "name": "Horizon",
  "version": "1.2.3",
  "description": "Moteur de synchronisation Cloud (Headless) pour Gens Launcher – multi-provider + sync incrémentale",
  "main": "index.js",
  "scripts": {
    "start"   : "node index.js",
    "login"   : "node index.js --login",
    "check"   : "node index.js --check",
    "upload"  : "node index.js --upload",
    "sync"    : "node index.js --sync",
    "dist"    : "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --out-path dist"
  },
  "repository": {
    "type": "git",
    "url" : "git+https://github.com/WilliamBossard/Gens-Horizon.git"
  },
  "author" : "William Bossard",
  "license": "ISC",
  "bin"    : "index.js",
  "pkg": {
    "assets": [
      "paths.js",
      "scanner.js",
      "config.js",
      "Auth.js",
      "provider.js",
      "providers/**/*"
    ],
    "scripts": [
      "login.js",
      "check.js",
      "sync.js",
      "upload.js"
    ]
  },
  "dependencies": {
    "adm-zip"   : "^0.5.17",
    "archiver"  : "^7.0.1",
    "googleapis": "^118.0.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
