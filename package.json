{
  "name": "Horizon",
  "version": "1.3.4",
  "description": "Moteur de synchronisation Cloud (Headless) pour Gens Launcher – multi-provider + sync incrémentale",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "login": "node index.js --login",
    "check": "node index.js --check",
    "upload": "node index.js --upload",
    "sync": "node index.js --sync",
    "dist": "pkg . --targets node24-win-x64,node24-linux-x64,node24-macos-x64 --out-path dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WilliamBossard/Gens-Horizon.git"
  },
  "author": "William Bossard",
  "license": "ISC",
  "bin": "index.js",
  "pkg": {
    "assets": [
      "paths.js",
      "scanner.js",
      "config.js",
      "Auth.js",
      "provider.js",
      "providers/**/*"
    ],
    "scripts": [
      "login.js",
      "check.js",
      "sync.js",
      "upload.js",
      "quota.js",
      "rollback.js"
    ]
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.20.0"
  }
}
